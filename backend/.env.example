# ==============================================
# 🚀 FERREALTIPLANO - BACKEND CONFIGURATION
# ==============================================

# ==============================================
# 🔧 GENERAL
# ==============================================
NODE_ENV=development
PORT=4000

# ==============================================
# 🗄️ DATABASE (PostgreSQL via Prisma)
# ==============================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ferrealtiplano?schema=public"

# ==============================================
# 🔐 JWT (Authentication)
# ==============================================
JWT_SECRET="tu_jwt_secret_muy_seguro_aqui_cambialo"
JWT_EXPIRES_IN=7d

# ==============================================
# ☁️ CLOUDINARY (Image Storage)
# ==============================================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ==============================================
# 💳 CULQI (Payment Processing - Perú)
# ==============================================
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxxxx

# ==============================================
# 🧾 NUBEFACT (Electronic Invoicing - Perú)
# ==============================================
NUBEFACT_API_URL=https://api.nubefact.com/v1
NUBEFACT_API_TOKEN=tu_nubefact_token

# ==============================================
# 🌐 CORS
# ==============================================
CORS_ORIGIN=http://localhost:5173
